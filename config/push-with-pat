#!/bin/zsh
# push-with-pat - Secure git push helper for 10nc3/2ndtry
# Usage: ./push-with-pat [git-push-args]

set -e

REPO_ROOT="/Users/avijja/.openclaw/workspace"
ENV_FILE="$HOME/.openclaw/.env"

if [[ ! -f "$ENV_FILE" ]]; then
    echo "Error: $ENV_FILE not found. PAT not stored."
    exit 1
fi

# Load PAT from secure env file
PAT=$(grep "GITHUB_PAT_10NC3_2NDTRY" "$ENV_FILE" | cut -d= -f2 | tr -d '[:space:]')

if [[ -z "$PAT" ]]; then
    echo "Error: GITHUB_PAT_10NC3_2NDTRY not found in $ENV_FILE"
    exit 1
fi

cd "$REPO_ROOT"

# Temporarily set remote with PAT
git remote set-url origin "https://10nc3:${PAT}@github.com/10nc3/2ndtry.git"

# Push with any extra args passed through
git push "$@"

# Scrub PAT from remote immediately
git remote set-url origin https://github.com/10nc3/2ndtry.git

echo "✅ Pushed. PAT scrubbed from remote."
